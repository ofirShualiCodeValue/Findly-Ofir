{
  "name": "findly-server",
  "version": "0.1.0",
  "private": true,
  "description": "Backend server for Findly — employer and employee apps",
  "main": "dist/server.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "build": "tsc && node -e \"require('fs').mkdirSync('dist/src/config',{recursive:true}); require('fs').copyFileSync('src/config/database.js','dist/src/config/database.js')\"",
    "db:migrate:dist": "node ./node_modules/sequelize-cli/lib/sequelize db:migrate --migrations-path dist/src/db/migrations --config dist/src/config/database.js --models-path dist/src/app/models",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only --watch src src/server.ts",
    "worker": "node dist/worker.js",
    "worker:dev": "ts-node-dev --respawn --transpile-only src/worker.ts",
    "cron": "node dist/cron.js",
    "console": "ts-node src/console.ts",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "sequelize": "ts-node ./node_modules/sequelize-cli/lib/sequelize",
    "g:migration": "npm run sequelize -- migration:generate",
    "g:seed": "npm run sequelize -- seed:generate",
    "db:migrate": "npm run sequelize -- db:migrate",
    "db:rollback": "npm run sequelize -- db:migrate:undo",
    "db:rollback:all": "npm run sequelize -- db:migrate:undo:all",
    "db:seed": "npm run sequelize -- db:seed:all",
    "db:seed:undo": "npm run sequelize -- db:seed:undo:all"
  },
  "dependencies": {
    "@monkeytech/nodejs-core": "^2.0.1-a-12.0",
    "compression": "^1.7.4",
    "convict": "^6.2.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.2.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.1",
    "pg": "^8.13.0",
    "pg-hstore": "^2.3.4",
    "redis": "^4.7.0",
    "reflect-metadata": "^0.2.2",
    "sequelize": "^6.37.5",
    "sequelize-typescript": "^2.1.6",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/convict": "^6.1.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/luxon": "^3.4.2",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.9.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "jest": "^29.7.0",
    "sequelize-cli": "^6.6.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
